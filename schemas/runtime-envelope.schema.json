{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sankarshanmukhopadhyay.github.io/governance-authority-assurance-metamodel/v0.9.0/schemas/runtime-envelope.schema.json",
  "title": "Runtime Envelope",
  "type": "object",
  "required": [
    "id",
    "type",
    "actor",
    "requestedEffect",
    "authority",
    "policy",
    "evidence",
    "decisionPoint"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "requestedEffect": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "policy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assurance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisionPoint": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
