{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/gaam/v0.5.0/schemas/governance-event.schema.json",
  "title": "Governance Event",
  "type": "object",
  "required": [
    "id",
    "type",
    "artifact",
    "eventType",
    "priorState",
    "newState",
    "authority",
    "eventTime"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "artifact": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "priorState": {
      "type": "string",
      "minLength": 1
    },
    "newState": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "eventTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
