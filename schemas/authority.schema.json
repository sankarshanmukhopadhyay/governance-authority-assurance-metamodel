{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/gaam/v0.5.0/schemas/authority.schema.json",
  "title": "Authority",
  "type": "object",
  "required": [
    "id",
    "type",
    "authoritySource",
    "issuer",
    "subject",
    "permittedEffects",
    "scope",
    "status",
    "effectiveFrom",
    "revocationAuthority",
    "accountableParties"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "proposed",
        "issued",
        "accepted",
        "active",
        "restricted",
        "suspended",
        "revoked",
        "expired",
        "superseded",
        "terminated",
        "archived",
        "contested",
        "remediated"
      ]
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },
    "authoritySource": {
      "type": "string",
      "minLength": 1
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "permittedEffects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "prohibitedEffects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object"
    },
    "delegationPermitted": {
      "type": "boolean"
    },
    "revocationAuthority": {
      "type": "string",
      "minLength": 1
    },
    "accountableParties": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
