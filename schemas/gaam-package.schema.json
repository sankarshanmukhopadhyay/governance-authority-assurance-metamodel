{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/gaam/v0.5.0/schemas/gaam-package.schema.json",
  "title": "Gaam Package",
  "type": "object",
  "required": [
    "id",
    "type",
    "gaamVersion",
    "status",
    "profiles",
    "artifacts",
    "schemas",
    "vocabularies",
    "integrity"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "gaam-governance-package"
    },
    "gaamVersion": {
      "const": "0.5.0"
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "superseded",
        "archived"
      ]
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "mediaType"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "vocabularies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "integrity": {
      "type": "object",
      "required": [
        "algorithm",
        "manifest"
      ],
      "properties": {
        "algorithm": {
          "const": "sha-256"
        },
        "manifest": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
