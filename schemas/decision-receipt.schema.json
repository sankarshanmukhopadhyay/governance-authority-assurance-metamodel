{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/gaam/v0.5.0/schemas/decision-receipt.schema.json",
  "title": "Decision Receipt",
  "type": "object",
  "required": [
    "id",
    "type",
    "decision",
    "authority",
    "policy",
    "outcome",
    "decisionTime",
    "enforcementPoint",
    "accountableParty"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "authority": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "policy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assurance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outcome": {
      "enum": [
        "permit",
        "deny",
        "permit-with-conditions",
        "restrict",
        "suspend",
        "require-additional-evidence",
        "require-additional-approval",
        "route-for-review",
        "terminate"
      ]
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisionTime": {
      "type": "string",
      "format": "date-time"
    },
    "enforcementPoint": {
      "type": "string",
      "minLength": 1
    },
    "accountableParty": {
      "type": "string",
      "minLength": 1
    },
    "reviewRoute": {
      "type": "string",
      "minLength": 1
    },
    "redactions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
