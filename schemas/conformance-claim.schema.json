{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sankarshanmukhopadhyay.github.io/governance-authority-assurance-metamodel/v0.9.0/schemas/conformance-claim.schema.json",
  "title": "Conformance Claim",
  "type": "object",
  "required": [
    "id",
    "type",
    "gaamVersion",
    "profiles",
    "target",
    "level",
    "evidence",
    "issuedBy",
    "issuedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "gaam-conformance-claim"
    },
    "gaamVersion": {
      "const": "0.9.0"
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "issuedBy": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "testSuiteVersion": {
      "type": "string",
      "minLength": 1
    },
    "assessmentIndependence": {
      "enum": [
        "self",
        "second-party",
        "independent"
      ]
    },
    "status": {
      "enum": [
        "active",
        "expired",
        "withdrawn",
        "superseded",
        "invalidated"
      ]
    },
    "reviewBy": {
      "type": "string",
      "format": "date-time"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
