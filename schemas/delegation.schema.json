{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sankarshanmukhopadhyay.github.io/governance-authority-assurance-metamodel/v0.9.0/schemas/delegation.schema.json",
  "title": "Delegation",
  "type": "object",
  "required": [
    "id",
    "type",
    "parentAuthority",
    "delegator",
    "delegate",
    "delegatedScope",
    "redelegation",
    "status",
    "effectiveFrom",
    "propagation"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "proposed",
        "issued",
        "accepted",
        "active",
        "restricted",
        "suspended",
        "revoked",
        "expired",
        "superseded",
        "terminated",
        "archived",
        "contested",
        "remediated"
      ]
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },
    "parentAuthority": {
      "type": "string",
      "minLength": 1
    },
    "delegator": {
      "type": "string",
      "minLength": 1
    },
    "delegate": {
      "type": "string",
      "minLength": 1
    },
    "delegatedScope": {
      "type": "object"
    },
    "redelegation": {
      "enum": [
        "prohibited",
        "permitted-with-attenuation",
        "permitted-as-specified"
      ]
    },
    "propagation": {
      "enum": [
        "immediate",
        "bounded-delay",
        "explicit-review"
      ]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
