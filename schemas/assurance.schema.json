{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/gaam/v0.5.0/schemas/assurance.schema.json",
  "title": "Assurance",
  "type": "object",
  "required": [
    "id",
    "type",
    "subject",
    "property",
    "criteria",
    "evaluator",
    "method",
    "evidence",
    "scope",
    "governanceContext",
    "status",
    "validFrom",
    "limitations",
    "challengeRoute"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "draft",
        "proposed",
        "issued",
        "accepted",
        "active",
        "restricted",
        "suspended",
        "revoked",
        "expired",
        "superseded",
        "terminated",
        "archived",
        "contested",
        "remediated"
      ]
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time"
    },
    "effectiveUntil": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "property": {
      "type": "string",
      "minLength": 1
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evaluator": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "scope": {
      "type": "object"
    },
    "governanceContext": {
      "type": "string",
      "minLength": 1
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "challengeRoute": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
